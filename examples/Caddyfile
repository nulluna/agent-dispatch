# agent-dispatch transparent proxy example for this machine
#
# Assumptions:
# 1. agent-dispatch runs locally with:
#    - explicit port:     8787
#    - transparent port:  8788
# 2. You have generated a trusted local certificate for anyrouter.top
# 3. /etc/hosts points the target domain to this machine, e.g.:
#      127.0.0.1 anyrouter.top
#
# Example certificate generation with mkcert:
#   mkcert -install
#   mkcert anyrouter.top
#
# Then place the generated files under:
#   /Users/you/projects/agent-tools/certs/anyrouter.top.pem
#   /Users/you/projects/agent-tools/certs/anyrouter.top-key.pem

https://domain {
  tls /path/to/domain.pem /path/to/domain.pem

  reverse_proxy 127.0.0.1:8788 {
    header_up X-Dispatch-Target-Host {host}
    header_up X-Forwarded-Host {host}
    header_up X-Forwarded-Proto https
  }
}

# Optional explicit proxy entry for /s and /h debugging.
http://127.0.0.1:8787 {
  reverse_proxy 127.0.0.1:8787
}
