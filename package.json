{
  "name": "agent-dispatch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node dispatch server for short-code proxy routing with optional SOCKS5 upstream proxy",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "fetch-socks": "^1.3.3",
    "undici": "^8.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
