{
  "name": "agent-dispatch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local HTTP ingress that dispatches requests to an internal agentproxy pool",
  "scripts": {
    "dev": "node scripts/wrangler.mjs dev",
