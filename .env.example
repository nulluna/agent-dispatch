# agent-dispatch explicit proxy listening port (/s and /h routes).
# Optional. If unset, explicit mode is disabled.
# PORT=8787

# transparent proxy dedicated port.
# Optional. If unset, transparent mode is disabled.
TRANSPARENT_PORT=8788

# Shared relay secret. Must match all agent-proxy backends.
DISPATCH_SECRET=replace-with-a-strong-secret

# Comma-separated agent-proxy backend URLs.
AGENT_PROXY_URLS=http://127.0.0.1:9001,http://127.0.0.1:9002

# Backend selection strategy: consistent-hashing or round-robin.
# Default is consistent-hashing.
BACKEND_SELECTION_STRATEGY=consistent-hashing

# Per-backend request timeout in milliseconds.
REQUEST_TIMEOUT_MS=5000

# Cooldown window after a backend fails with a retryable error.
FAILOVER_COOLDOWN_MS=3000
